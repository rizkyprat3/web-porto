# ── Secrets template ──────────────────────────────────────────────
# Copy to .env.local (NEVER commit .env.local).
# Only variables prefixed NEXT_PUBLIC_ are exposed to the browser.

# Supabase (server-side; used by the contact form API route)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Public site URL (for SEO metadata / sitemap)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
